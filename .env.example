# ══════════════════════════════════════════════════════════════════════════════
# DiagGen+ — Environment Variables Template
# Copy this file to .env and fill in your keys. NEVER commit .env to Git.
# ══════════════════════════════════════════════════════════════════════════════

# ── LLM API Keys (only the active provider needs to be set) ──────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
# Ollama runs locally — no key needed

# ── Hugging Face (optional — needed only for private/gated models) ────────────
HUGGINGFACE_TOKEN=your_hf_token_here

# ── MLflow (optional override — default path set in config.yaml) ─────────────
# MLFLOW_TRACKING_URI=http://localhost:5000
